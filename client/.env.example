# Leave these blank in local development to use the built-in Vite proxy.
# In production, leave VITE_API_URL blank when the app and API share one origin.
# Set VITE_API_URL only when your backend lives on another domain.
# Set VITE_SERVER_URL only when a separate realtime server is available.
VITE_API_URL=
VITE_SERVER_URL=
VITE_GOOGLE_CLIENT_ID=
VITE_WEB_PUSH_PUBLIC_KEY=
